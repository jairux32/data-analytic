# =============================================================================
# CONFIGURACIÓN DE APLICACIÓN - Diagnóstico Socioambiental Cacaotero
# =============================================================================
# Copia este archivo a .env y completa los valores

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE BASE DE DATOS
# -----------------------------------------------------------------------------
POSTGRES_USER=kobo_cacao
POSTGRES_PASSWORD=kobo_cacao_pass
POSTGRES_DB=kobo_cacao_db
DATABASE_URL=postgresql://kobo_cacao:kobo_cacao_pass@postgres:5432/kobo_cacao_db

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE SEGURIDAD
# -----------------------------------------------------------------------------
# Genera una clave secreta segura: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE REDIS (CACHÉ)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE KOBOTOOLBOX
# -----------------------------------------------------------------------------
# URL de la instancia de KoboToolbox (usualmente https://kf.kobotoolbox.org)
KOBO_INSTANCE_URL=https://kf.kobotoolbox.org
# Token de API de KoboToolbox (obtener desde cuenta de usuario)
KOBO_API_TOKEN=your-kobo-api-token-here
# Asset UIDs de formularios (separados por coma si hay múltiples)
KOBO_ASSET_UIDS=your-asset-uid-here
# Frecuencia de sincronización automática en horas (0 = desactivado)
KOBO_SYNC_INTERVAL_HOURS=0

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE APLICACIÓN
# -----------------------------------------------------------------------------
APP_NAME=Diagnóstico Socioambiental Cacaotero
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE CORREO (opcional - para recuperación de contraseña)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE EXPORTACIÓN
# -----------------------------------------------------------------------------
# Ruta para almacenar archivos temporales de exportación
EXPORT_TEMP_DIR=/tmp/exports
# Días antes de eliminar archivos temporales
EXPORT_CLEANUP_DAYS=7

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
